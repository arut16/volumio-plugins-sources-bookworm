{
  "page": {
    "label": "TRANSLATE.PLUGIN_CONFIGURATION"
  },
  "sections": [
    {
      "id": "settings",
      "element": "section",
      "label": "TRANSLATE.SETTINGS",
      "icon": "fa-clock-o",
      "onSave": {
        "type": "plugin",
        "endpoint": "system_hardware/pirate_audio_screensaver",
        "method": "saveSettings"
      },
      "saveButton": {
        "label": "TRANSLATE.SAVE",
        "data": ["idle_delay_seconds", "display_rotation"]
      },
      "content": [
        {
          "id": "idle_delay_seconds",
          "element": "input",
          "label": "TRANSLATE.IDLE_DELAY_SECONDS",
          "doc": "TRANSLATE.IDLE_DELAY_SECONDS_DOC",
          "attributes": [
            { "type": "number" },
            { "min": 10 },
            { "step": 1 }
          ],
          "value": 300
        },
        {
          "id": "display_rotation",
          "element": "select",
          "label": "TRANSLATE.DISPLAY_ROTATION",
          "doc": "TRANSLATE.DISPLAY_ROTATION_DOC",
          "options": [
            { "value": 0, "label": "0" },
            { "value": 90, "label": "90" },
            { "value": 180, "label": "180" },
            { "value": 270, "label": "270" }
          ],
          "value": { "value": 90, "label": "90" }
        }
      ]
    }
  ]
}
